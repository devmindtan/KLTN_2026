# PostgreSQL Database
POSTGRES_HOST=
POSTGRES_DBS=
POSTGRES_USERNAME=
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# MinIO Storage
MINIO_ENDPOINT_URL=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=reports

# Report Config (JSON) - truyền bởi server khi spawn process
# Khi test thủ công: truyền qua CLI --config hoặc set env này
# REPORT_CONFIG={"type":"daily","period_from":"2026-03-01","period_to":"2026-03-18","title":"Báo cáo test","settings":{}}

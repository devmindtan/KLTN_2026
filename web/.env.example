VITE_SOCKET_URL=
VITE_MINIO_URL=
VITE_BACKEND_URL=
VITE_LOG=true

# Nhãn trạng thái giao thông (LOS – Level of Service)
# Các giá trị này là single source of truth cho toàn frontend.
# Nếu không set, fallback mặc định trong src/lib/los-config.ts sẽ được dùng.
VITE_LOS_FREE_FLOW=Thông thoáng
VITE_LOS_SMOOTH=Trôi chảy
VITE_LOS_MODERATE=Vừa phải
VITE_LOS_HEAVY=Đông đúc
VITE_LOS_CONGESTED=Ùn tắc
